{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/docs",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec next build",
        "cwd": "apps/docs"
      },
      "configurations": {
        "stable": { "env": { "DS_SCOPE": "stable" } },
        "experimental": { "env": { "DS_SCOPE": "experimental" } }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec next dev -p 6010",
        "cwd": "apps/docs"
      }
    }
  }
}
