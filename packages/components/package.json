{
  "name": "@namirial/components",
  "version": "0.0.0",
  "description": "Namirial Design System — Stencil web components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader/index.d.ts",
      "import": "./dist/loader/index.js",
      "default": "./dist/loader/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch",
    "test": "stencil test"
  },
  "dependencies": {
    "@namirial/design-system": "workspace:*"
  },
  "devDependencies": {
    "@stencil/core": "^4.5.0",
    "typescript": "5.6.3"
  }
}
