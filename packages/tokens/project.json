{
  "name": "tokens",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/tokens/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run tokens:tsc",
          "node packages/tokens/dist/src/build-tokens.js"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      },
      "configurations": { "stable": {}, "experimental": {} }
    },
    "tsc": {
      "executor": "@nx/js:tsc",
      "options": {
        "outputPath": "packages/tokens/dist",
        "main": "packages/tokens/src/index.ts",
        "tsConfig": "packages/tokens/tsconfig.json"
      }
    }
  }
}
